<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ScalarScope.Views.HelpPage"
             Title="Interpretation Guide"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#0f0f1a}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="24">

            <!-- Header -->
            <Label Text="Interpretation Guide"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}" />

            <!-- Search/Filter Bar -->
            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1a1a2e}"
                   Stroke="{AppThemeBinding Light=#DDDDDD, Dark=#2a2a4e}"
                   StrokeShape="RoundRectangle 8"
                   Padding="12">
                <SearchBar x:Name="searchBar"
                          Placeholder="Search deltas, metrics, visualizations..."
                          PlaceholderColor="{AppThemeBinding Light=#999999, Dark=#666666}"
                          TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}"
                          BackgroundColor="Transparent"
                          SearchCommand="{x:Null}"
                          TextChanged="OnSearchTextChanged" />
            </Border>

            <!-- Delta Glossary - Primary Section -->
            <Border x:Name="deltaGlossarySection"
                   BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1a1a2e}"
                   Stroke="#ff6b6b"
                   StrokeShape="RoundRectangle 12"
                   Padding="20">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Delta Glossary (δ-spec v3.2.0)"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#ff6b6b" />
                    <Label Text="Each delta below explains what fired and why. Click 'See in context' to view an example."
                           TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"
                           FontSize="13" />

                    <!-- ΔF (Failure Rate) -->
                    <Border x:Name="deltaFSection"
                           BackgroundColor="{AppThemeBinding Light=#FFF5F5, Dark=#2a1a1a}"
                           Stroke="#ff6b6b"
                           StrokeShape="RoundRectangle 8"
                           Padding="16">
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="ΔF" FontSize="18" FontAttributes="Bold" TextColor="#ff6b6b" VerticalOptions="Center" />
                                <Label Text="Failure Rate Delta" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="When it fires: σ(FA - FB) ≥ 0.05 (failure rates differ by ≥5%)"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="What it means: One training path produces significantly more failed outputs than the other. A lower failure rate indicates more reliable convergence."
                                   TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}" />
                            <Label Text="Guardrail: Confidence depends on sample size. Small n may cause noisy estimates."
                                   TextColor="#ffd93d" FontSize="12" FontAttributes="Italic" />
                            <Button Text="See in context →"
                                    Clicked="OnSeeInContextClicked"
                                    CommandParameter="failure"
                                    BackgroundColor="#ff6b6b"
                                    TextColor="White"
                                    CornerRadius="6"
                                    HeightRequest="32"
                                    Padding="12,0"
                                    HorizontalOptions="Start" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- ΔTc (Convergence Time) -->
                    <Border x:Name="deltaTcSection"
                           BackgroundColor="{AppThemeBinding Light=#F5F5FF, Dark=#1a1a2e}"
                           Stroke="#4ecdc4"
                           StrokeShape="RoundRectangle 8"
                           Padding="16">
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="ΔTc" FontSize="18" FontAttributes="Bold" TextColor="#4ecdc4" VerticalOptions="Center" />
                                <Label Text="Convergence Time Delta" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="When it fires: |TcA - TcB| ≥ 10% of max(TcA, TcB)"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="What it means: Training paths reach stable loss at different rates. Faster convergence isn't always better—it may indicate premature convergence to a suboptimal minimum."
                                   TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}" />
                            <Label Text="Guardrail: Consider ΔTc alongside final loss values. Fast + bad loss = concerning."
                                   TextColor="#ffd93d" FontSize="12" FontAttributes="Italic" />
                            <Button Text="See in context →"
                                    Clicked="OnSeeInContextClicked"
                                    CommandParameter="convergence"
                                    BackgroundColor="#4ecdc4"
                                    TextColor="#0f0f1a"
                                    CornerRadius="6"
                                    HeightRequest="32"
                                    Padding="12,0"
                                    HorizontalOptions="Start" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- ΔTd (Dominance Time) -->
                    <Border x:Name="deltaTdSection"
                           BackgroundColor="{AppThemeBinding Light=#FFF8F0, Dark=#2a2a1a}"
                           Stroke="#ff9f43"
                           StrokeShape="RoundRectangle 8"
                           Padding="16">
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="ΔTd" FontSize="18" FontAttributes="Bold" TextColor="#ff9f43" VerticalOptions="Center" />
                                <Label Text="Dominance Time Delta" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="When it fires: |TdA - TdB| ≥ 15% of max(TdA, TdB) where Td = epoch when λ₁/Σλ ≥ 0.7"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="What it means: Paths develop eigenvalue dominance at different rates. Earlier dominance suggests faster emergence of a shared evaluative axis."
                                   TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}" />
                            <Label Text="⚠️ Guardrail: Dominance ≠ collapse. High λ₁ with good generalization is fine. High λ₁ with rising validation loss = mode collapse."
                                   TextColor="#ff6b6b" FontSize="12" FontAttributes="Bold" />
                            <Button Text="See in context →"
                                    Clicked="OnSeeInContextClicked"
                                    CommandParameter="dominance"
                                    BackgroundColor="#ff9f43"
                                    TextColor="#0f0f1a"
                                    CornerRadius="6"
                                    HeightRequest="32"
                                    Padding="12,0"
                                    HorizontalOptions="Start" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- ΔĀ (Aligned Direction) -->
                    <Border x:Name="deltaASection"
                           BackgroundColor="{AppThemeBinding Light=#F5FFF5, Dark=#1a2e1a}"
                           Stroke="#4ecdc4"
                           StrokeShape="RoundRectangle 8"
                           Padding="16">
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="ΔĀ" FontSize="18" FontAttributes="Bold" TextColor="#4ecdc4" VerticalOptions="Center" />
                                <Label Text="Alignment Delta" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="When it fires: |cosθ(v₁A, v₁B)| ≥ 0.85 (converged to similar principal direction)"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="What it means: Both paths found a similar 'quality axis' despite different training dynamics. High alignment suggests a robust latent structure in the evaluator ensemble."
                                   TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}" />
                            <Label Text="⚠️ Guardrail: Agreement ≠ correctness. Both paths could converge to the same wrong answer if evaluators share systematic bias."
                                   TextColor="#ff6b6b" FontSize="12" FontAttributes="Bold" />
                            <Button Text="See in context →"
                                    Clicked="OnSeeInContextClicked"
                                    CommandParameter="alignment"
                                    BackgroundColor="#4ecdc4"
                                    TextColor="#0f0f1a"
                                    CornerRadius="6"
                                    HeightRequest="32"
                                    Padding="12,0"
                                    HorizontalOptions="Start" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- ΔO (Oscillation Index) -->
                    <Border x:Name="deltaOSection"
                           BackgroundColor="{AppThemeBinding Light=#F8F0FF, Dark=#2a1a2e}"
                           Stroke="#c56cf0"
                           StrokeShape="RoundRectangle 8"
                           Padding="16">
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="ΔO" FontSize="18" FontAttributes="Bold" TextColor="#c56cf0" VerticalOptions="Center" />
                                <Label Text="Oscillation Index Delta" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="When it fires: |OA - OB| ≥ 0.15 where O = stddev of angular velocity over window"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="What it means: Training stability differs—one path shows more 'thrashing' in parameter space. High oscillation may indicate conflicting gradient signals from evaluators."
                                   TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}" />
                            <Label Text="⚠️ Guardrail: Instability ≠ failure. Some exploration is healthy. Only concerning if oscillation persists without loss improvement."
                                   TextColor="#ff6b6b" FontSize="12" FontAttributes="Bold" />
                            <Button Text="See in context →"
                                    Clicked="OnSeeInContextClicked"
                                    CommandParameter="oscillation"
                                    BackgroundColor="#c56cf0"
                                    TextColor="White"
                                    CornerRadius="6"
                                    HeightRequest="32"
                                    Padding="12,0"
                                    HorizontalOptions="Start" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- What You Just Saw (shows after demo completion) -->
            <Border x:Name="demoRecapFrame"
                   BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1a2e1a}"
                   Stroke="#4ecdc4"
                   StrokeShape="RoundRectangle 12"
                   Padding="20"
                   IsVisible="False">
                <VerticalStackLayout Spacing="12">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="✓"
                               FontSize="20"
                               TextColor="#4ecdc4"
                               VerticalOptions="Center"/>
                        <Label Text="What You Just Saw"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#4ecdc4"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <Label Text="The demo compared two training runs with identical settings except for evaluator geometry:"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,5">
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="Path A: Orthogonal"
                                   FontAttributes="Bold"
                                   TextColor="#ff6b6b"/>
                            <Label Text="Professors with independent criteria (r ≈ 0). Eigenvalues stayed distributed. No unified axis emerged."
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"
                                   FontSize="12"
                                   LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="Path B: Correlated"
                                   FontAttributes="Bold"
                                   TextColor="#4ecdc4"/>
                            <Label Text="Professors sharing latent quality (r ≈ 0.87). λ₁ dominated the spectrum. Model converged to shared axis."
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"
                                   FontSize="12"
                                   LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="Key insight: Evaluative internalization is possible if and only if evaluators share a latent evaluative manifold."
                           TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}"
                           FontAttributes="Italic"
                           Margin="0,5,0,0"/>

                    <Button Text="Watch Demo Again"
                            x:Name="replayDemoButton"
                            Clicked="OnReplayDemoClicked"
                            BackgroundColor="#4ecdc4"
                            TextColor="#0f0f1a"
                            FontSize="12"
                            Padding="12,6"
                            HeightRequest="32"
                            CornerRadius="6"
                            HorizontalOptions="Start"
                            Margin="0,5,0,0"/>
                </VerticalStackLayout>
            </Border>

            <!-- Visual Patterns Guide -->
            <Border x:Name="visualPatternsSection"
                   BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1a1a2e}"
                   Stroke="#00d9ff"
                   StrokeShape="RoundRectangle 12"
                   Padding="20">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Visual Patterns &amp; What They Mean"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#00d9ff" />

                    <!-- Trajectory Shapes -->
                    <Border x:Name="trajectorySection"
                           BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#0f0f1a}"
                           Stroke="Transparent"
                           StrokeShape="RoundRectangle 8"
                           Padding="16">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Trajectory Shapes → ΔF, ΔTc"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#333333, Dark=#4ecdc4}" />
                            <Label Text="• Smooth convergence → Low ΔF likely (stable learning)"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Spiraling path → Check ΔO (oscillation between objectives)"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Sharp turns → Phase transitions, may affect ΔTc"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Stagnation → Possible ΔTc fire if paths differ in plateau timing"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Eigenvalue Dominance -->
                    <Border x:Name="eigenvalueSection"
                           BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#0f0f1a}"
                           Stroke="Transparent"
                           StrokeShape="RoundRectangle 8"
                           Padding="16">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Eigenvalue Dominance → ΔTd, ΔĀ"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#333333, Dark=#ff9f43}" />
                            <Label Text="• Single dominant λ₁ (>70%) → ΔTd fires if timing differs"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Distributed eigenvalues → ΔTd unlikely (no clear dominance)"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Collapsing spectrum → Watch for ΔĀ (alignment emerging)"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Rising λ₁ + validation loss → Mode collapse risk (guardrail!)"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Scalar Rings -->
                    <Border x:Name="scalarRingsSection"
                           BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#0f0f1a}"
                           Stroke="Transparent"
                           StrokeShape="RoundRectangle 8"
                           Padding="16">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Scalar Rings (Vortex View) → ΔO"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#333333, Dark=#c56cf0}" />
                            <Label Text="• Phase-locked rings → Low ΔO (dimensions improving together)"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Drifting phases → Higher ΔO may fire (tradeoffs occurring)"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Expanding radius → Metric improvement over time"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Jittery rotation → Instability signal, check ΔO + ΔF"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Delta Hierarchy Guide -->
            <Border x:Name="deltaHierarchySection"
                   BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1a1a2e}"
                   Stroke="{AppThemeBinding Light=#DDDDDD, Dark=#2a2a4e}"
                   StrokeShape="RoundRectangle 12"
                   Padding="20">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Reading Delta Priority"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#ffd93d}" />
                    <Label Text="When multiple deltas fire, read them in this order (most fundamental → derived):"
                           TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />

                    <VerticalStackLayout Spacing="8" Padding="10,0">
                        <Label Text="1️⃣ ΔF (Failure Rate) — Did one path fail more?"
                               TextColor="{AppThemeBinding Light=#333333, Dark=#ff6b6b}" FontAttributes="Bold" />
                        <Label Text="2️⃣ ΔTc (Convergence Time) — Did they converge at different speeds?"
                               TextColor="{AppThemeBinding Light=#333333, Dark=#4ecdc4}" FontAttributes="Bold" />
                        <Label Text="3️⃣ ΔTd (Dominance Time) — Did eigenvalue dominance emerge differently?"
                               TextColor="{AppThemeBinding Light=#333333, Dark=#ff9f43}" FontAttributes="Bold" />
                        <Label Text="4️⃣ ΔĀ (Alignment) — Did they find the same quality axis?"
                               TextColor="{AppThemeBinding Light=#333333, Dark=#4ecdc4}" FontAttributes="Bold" />
                        <Label Text="5️⃣ ΔO (Oscillation) — Was one path more stable?"
                               TextColor="{AppThemeBinding Light=#333333, Dark=#c56cf0}" FontAttributes="Bold" />
                    </VerticalStackLayout>

                    <Label Text="💡 Tip: ΔF issues explain ΔTc; ΔTc explains ΔTd; ΔTd explains ΔĀ. Read upstream first."
                           TextColor="{AppThemeBinding Light=#666666, Dark=#ffd93d}"
                           FontSize="13"
                           FontAttributes="Italic" />
                </VerticalStackLayout>
            </Border>

            <!-- Quick Actions -->
            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1a1a2e}"
                   Stroke="{AppThemeBinding Light=#DDDDDD, Dark=#2a2a4e}"
                   StrokeShape="RoundRectangle 12"
                   Padding="20">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Quick Actions"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}" />

                    <FlexLayout Wrap="Wrap" JustifyContent="Start">
                        <Button Text="🔍 Run Diagnostics"
                                Clicked="OnRunDiagnosticsClicked"
                                BackgroundColor="#4ecdc4"
                                TextColor="White"
                                Margin="0,0,12,12"
                                Padding="16,10"
                                CornerRadius="8" />

                        <Button Text="📦 Create Support Bundle"
                                Clicked="OnCreateSupportBundleClicked"
                                BackgroundColor="{AppThemeBinding Light=#DDDDDD, Dark=#2a2a4e}"
                                TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}"
                                Margin="0,0,12,12"
                                Padding="16,10"
                                CornerRadius="8" />

                        <Button Text="📋 Copy System Info"
                                Clicked="OnCopySystemInfoClicked"
                                BackgroundColor="{AppThemeBinding Light=#DDDDDD, Dark=#2a2a4e}"
                                TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}"
                                Margin="0,0,12,12"
                                Padding="16,10"
                                CornerRadius="8" />
                    </FlexLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Diagnostics Result (hidden by default) -->
            <Border x:Name="DiagnosticsFrame"
                   IsVisible="False"
                   BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#16213e}"
                   Stroke="{AppThemeBinding Light=#DDDDDD, Dark=#2a2a4e}"
                   StrokeShape="RoundRectangle 12"
                   Padding="20">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Diagnostics Results"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}" />

                    <Label x:Name="DiagnosticsResultLabel"
                           FontFamily="Consolas"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#AAAAAA}" />
                </VerticalStackLayout>
            </Border>

            <!-- Common Issues -->
            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1a1a2e}"
                   Stroke="{AppThemeBinding Light=#DDDDDD, Dark=#2a2a4e}"
                   StrokeShape="RoundRectangle 12"
                   Padding="20">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Common Issues"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}" />

                    <!-- Issue 1 -->
                    <Border BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#0f0f1a}"
                           Stroke="Transparent"
                           StrokeShape="RoundRectangle 8"
                           Padding="16">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="❌ File won't load"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}" />
                            <Label Text="• Ensure the file is valid JSON format"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Check the file isn't corrupted or truncated"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Verify the schema matches ScalarScope training run format"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Issue 2 -->
                    <Border BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#0f0f1a}"
                           Stroke="Transparent"
                           StrokeShape="RoundRectangle 8"
                           Padding="16">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="🐌 Slow or choppy playback"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}" />
                            <Label Text="• Close other GPU-intensive applications"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Try reducing the export resolution"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Update your graphics drivers"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Issue 3 -->
                    <Border BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#0f0f1a}"
                           Stroke="Transparent"
                           StrokeShape="RoundRectangle 8"
                           Padding="16">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="📸 Export fails"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}" />
                            <Label Text="• Ensure you have write access to the destination"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Check available disk space (Run Diagnostics)"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Try a lower resolution export"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Issue 4 -->
                    <Border BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#0f0f1a}"
                           Stroke="Transparent"
                           StrokeShape="RoundRectangle 8"
                           Padding="16">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="🔧 App crashes on startup"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}" />
                            <Label Text="• Delete settings: %LOCALAPPDATA%\ScalarScope\settings.json"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Reinstall the application"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Create a support bundle and report the issue"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Issue 5 -->
                    <Border BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#0f0f1a}"
                           Stroke="Transparent"
                           StrokeShape="RoundRectangle 8"
                           Padding="16">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="⌨️ Keyboard shortcuts not working"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}" />
                            <Label Text="• Click inside the visualization area first"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• Check if another window has focus"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                            <Label Text="• See QUICK_REFERENCE.md for shortcut list"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </Border>

            <!-- Keyboard Shortcuts -->
            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1a1a2e}"
                   Stroke="{AppThemeBinding Light=#DDDDDD, Dark=#2a2a4e}"
                   StrokeShape="RoundRectangle 12"
                   Padding="20">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Keyboard Shortcuts"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}" />

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="24" RowSpacing="8">
                        <Label Grid.Row="0" Grid.Column="0" Text="Space" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#00d9ff}" />
                        <Label Grid.Row="0" Grid.Column="1" Text="Play / Pause" TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />

                        <Label Grid.Row="1" Grid.Column="0" Text="← / →" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#00d9ff}" />
                        <Label Grid.Row="1" Grid.Column="1" Text="Step backward / forward" TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Home / End" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#00d9ff}" />
                        <Label Grid.Row="2" Grid.Column="1" Text="Jump to start / end" TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />

                        <Label Grid.Row="3" Grid.Column="0" Text="+ / -" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#00d9ff}" />
                        <Label Grid.Row="3" Grid.Column="1" Text="Increase / decrease speed" TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />

                        <Label Grid.Row="4" Grid.Column="0" Text="S" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#00d9ff}" />
                        <Label Grid.Row="4" Grid.Column="1" Text="Take screenshot" TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />

                        <Label Grid.Row="5" Grid.Column="0" Text="Ctrl+O" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=#00d9ff}" />
                        <Label Grid.Row="5" Grid.Column="1" Text="Open file" TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- About -->
            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1a1a2e}"
                   Stroke="{AppThemeBinding Light=#DDDDDD, Dark=#2a2a4e}"
                   StrokeShape="RoundRectangle 12"
                   Padding="20">
                <VerticalStackLayout Spacing="12">
                    <Label Text="About ScalarScope"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}" />

                    <Label Text="Version 1.0.0-rc.1"
                           TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />

                    <Label Text="Visualization tool for machine learning training dynamics."
                           TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}" />

                    <Label Text="© 2025 ScalarScope (mcp-tool-shop-org)"
                           TextColor="{AppThemeBinding Light=#888888, Dark=#666666}" />

                    <HorizontalStackLayout Spacing="16" Margin="0,8,0,0">
                        <Button Text="GitHub"
                                Clicked="OnGitHubClicked"
                                BackgroundColor="Transparent"
                                TextColor="#00d9ff"
                                Padding="0" />
                        <Button Text="Report Issue"
                                Clicked="OnReportIssueClicked"
                                BackgroundColor="Transparent"
                                TextColor="#00d9ff"
                                Padding="0" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
