<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ScalarScope.Views.Controls.AdvancedSection"
             x:Name="root">

    <VerticalStackLayout Spacing="0">
        <!-- Expand/Collapse Header -->
        <Border BackgroundColor="#1a1a2e"
                StrokeThickness="0"
                Padding="8,6">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnHeaderTapped"/>
            </Border.GestureRecognizers>
            <HorizontalStackLayout Spacing="6">
                <Label x:Name="expandIcon"
                       Text="▸"
                       TextColor="#666"
                       FontSize="10"
                       VerticalOptions="Center"/>
                <Label Text="{Binding HeaderText, Source={x:Reference root}}"
                       TextColor="#888"
                       FontSize="11"
                       VerticalOptions="Center"/>
                <Label Text="(optional)"
                       TextColor="#444"
                       FontSize="10"
                       FontAttributes="Italic"
                       VerticalOptions="Center"
                       IsVisible="{Binding IsExpanded, Source={x:Reference root}, Converter={StaticResource InverseBoolConverter}}"/>
            </HorizontalStackLayout>
        </Border>
        
        <!-- Expandable Content -->
        <Border x:Name="contentBorder"
                BackgroundColor="#14141e"
                StrokeThickness="0"
                Padding="12,8"
                IsVisible="{Binding IsExpanded, Source={x:Reference root}}">
            <ContentPresenter Content="{Binding AdvancedContent, Source={x:Reference root}}"/>
        </Border>
    </VerticalStackLayout>
</ContentView>
