<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ScalarScope.ViewModels"
             x:Class="ScalarScope.Views.WelcomePage"
             x:DataType="vm:WelcomeViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0f0f1a">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- Typography -->
            <Style x:Key="SectionHeader" TargetType="Label">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="TextColor" Value="#666"/>
                <Setter Property="CharacterSpacing" Value="1.5"/>
            </Style>
            <Style x:Key="ItemTitle" TargetType="Label">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="TextColor" Value="White"/>
            </Style>
            <Style x:Key="ItemDescription" TargetType="Label">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="TextColor" Value="#888"/>
            </Style>
            <Style x:Key="StatusText" TargetType="Label">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="TextColor" Value="#666"/>
            </Style>
            
            <!-- Card -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="BackgroundColor" Value="#16213e"/>
                <Setter Property="Stroke" Value="#2a2a4e"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="StrokeShape" Value="RoundRectangle 8"/>
                <Setter Property="Padding" Value="16"/>
            </Style>
            
            <!-- Action Button -->
            <Style x:Key="ActionButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#2a2a4e"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="HeightRequest" Value="36"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Padding" Value="16,0"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Padding="24">
        
        <!-- Header: App Identity -->
        <HorizontalStackLayout Grid.Row="0" Spacing="12" Margin="0,0,0,24">
            <Border BackgroundColor="#1a1a2e"
                    StrokeShape="RoundRectangle 8"
                    Stroke="#2a2a4e"
                    HeightRequest="40"
                    WidthRequest="40">
                <Label Text="📊" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            <VerticalStackLayout VerticalOptions="Center">
                <Label Text="ScalarScope" FontSize="18" FontAttributes="Bold" TextColor="White"/>
                <Label Text="Inference comparison instrument" Style="{StaticResource StatusText}"/>
            </VerticalStackLayout>
        </HorizontalStackLayout>

        <!-- Main Content -->
        <ScrollView Grid.Row="1">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="24" RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="24">
                
                <!-- Section: Current Workspace -->
                <VerticalStackLayout Grid.Row="0" Grid.ColumnSpan="2" Spacing="12">
                    <Label Text="WORKSPACE" Style="{StaticResource SectionHeader}"/>
                    
                    <Border Style="{StaticResource Card}">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding WorkspaceStatus}" Style="{StaticResource ItemTitle}"/>
                                <Label Text="{Binding WorkspaceDetail}" Style="{StaticResource ItemDescription}"/>
                            </VerticalStackLayout>
                            
                            <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                                <Button Text="Load Runs"
                                        Style="{StaticResource ActionButton}"
                                        Command="{Binding NavigateToCompareCommand}"
                                        IsVisible="{Binding CanLoadRuns}"
                                        AutomationProperties.Name="Load Runs"/>
                                <Button Text="Open Bundle"
                                        Style="{StaticResource ActionButton}"
                                        Command="{Binding OpenBundleCommand}"
                                        AutomationProperties.Name="Open Bundle"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Section: Capabilities Header -->
                <Label Grid.Row="1" Grid.ColumnSpan="2" Text="CAPABILITIES" Style="{StaticResource SectionHeader}"/>

                <!-- Section: Capabilities (Left Column) -->
                <VerticalStackLayout Grid.Row="2" Grid.Column="0" Spacing="12">
                    
                    <!-- Compare -->
                    <Border Style="{StaticResource Card}">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Label Text="⚖️" FontSize="20" VerticalOptions="Start"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Compare" Style="{StaticResource ItemTitle}"/>
                                <Label Text="Load two inference runs and see what changed. Convergence, latency, throughput—measured with confidence intervals."
                                       Style="{StaticResource ItemDescription}"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                    
                    <!-- Explain -->
                    <Border Style="{StaticResource Card}">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Label Text="💡" FontSize="20" VerticalOptions="Start"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Explain" Style="{StaticResource ItemTitle}"/>
                                <Label Text="Each delta includes a Why panel explaining what triggered it and what it means for your optimization."
                                       Style="{StaticResource ItemDescription}"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Section: Capabilities (Right Column) -->
                <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="12">
                    
                    <!-- Export -->
                    <Border Style="{StaticResource Card}">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Label Text="📦" FontSize="20" VerticalOptions="Start"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Export" Style="{StaticResource ItemTitle}"/>
                                <Label Text="Create reproducible bundles with SHA-256 integrity. Share findings without sharing raw data."
                                       Style="{StaticResource ItemDescription}"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                    
                    <!-- Review -->
                    <Border Style="{StaticResource Card}">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Label Text="🔍" FontSize="20" VerticalOptions="Start"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Review" Style="{StaticResource ItemTitle}"/>
                                <Label Text="Open bundles from colleagues. The entire analysis is frozen and verified against the original hash."
                                       Style="{StaticResource ItemDescription}"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Section: Sample Workflow -->
                <VerticalStackLayout Grid.Row="3" Grid.Column="0" Spacing="12">
                    <Label Text="SAMPLE WORKFLOW" Style="{StaticResource SectionHeader}"/>
                    
                    <Border Style="{StaticResource Card}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="TFRT Optimization Example" Style="{StaticResource ItemTitle}"/>
                                <Label Text="See a real before/after comparison with deltas, explanations, and export."
                                       Style="{StaticResource ItemDescription}"/>
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    Text="Click Here"
                                    Style="{StaticResource ActionButton}"
                                    Command="{Binding TryExampleCommand}"
                                    VerticalOptions="Center"
                                    AutomationProperties.Name="Load Sample"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Section: Recent -->
                <VerticalStackLayout Grid.Row="3" Grid.Column="1" Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="RECENT" Style="{StaticResource SectionHeader}"/>
                        <Button Text="Clear"
                                Grid.Column="1"
                                BackgroundColor="Transparent"
                                TextColor="#666"
                                FontSize="10"
                                HeightRequest="20"
                                Padding="4,0"
                                Command="{Binding ClearRecentCommand}"
                                IsVisible="{Binding HasRecentComparisons}"/>
                    </Grid>
                    
                    <!-- Recent Items -->
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding RecentComparisons}"
                                         Spacing="8"
                                         IsVisible="{Binding HasRecentComparisons}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:RecentComparisonItem">
                                <Border Style="{StaticResource Card}" Padding="12">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:WelcomeViewModel}}, Path=OpenRecentCommand}"
                                                              CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding Title}" Style="{StaticResource ItemTitle}" FontSize="13" LineBreakMode="TailTruncation"/>
                                            <Label Text="{Binding Subtitle}" Style="{StaticResource ItemDescription}" FontSize="11" LineBreakMode="TailTruncation"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1" Text="{Binding TimeAgo}" Style="{StaticResource StatusText}" VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                    
                    <!-- Empty State -->
                    <Border Style="{StaticResource Card}" 
                            IsVisible="{Binding HasRecentComparisons, Converter={StaticResource InverseBoolConverter}}"
                            Opacity="0.6">
                        <Label Text="No recent comparisons" Style="{StaticResource StatusText}" HorizontalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

            </Grid>
        </ScrollView>
        
        <!-- Footer -->
        <HorizontalStackLayout Grid.Row="2" Spacing="16" HorizontalOptions="Center" Margin="0,16,0,0">
            <Label Text="v2.0.0" Style="{StaticResource StatusText}"/>
            <Label Text="•" Style="{StaticResource StatusText}" Opacity="0.4"/>
            <Label Text="DeltaSpec 1.0" Style="{StaticResource StatusText}"/>
            <Label Text="•" Style="{StaticResource StatusText}" Opacity="0.4"/>
            <Label Text="Local only" Style="{StaticResource StatusText}" TextColor="#00ff88"/>
        </HorizontalStackLayout>
    </Grid>

</ContentPage>
